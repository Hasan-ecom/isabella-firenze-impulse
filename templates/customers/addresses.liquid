<div class="customer-page customer-addresses">
  <div class="customer-page__inner customer-addresses__inner">
    <div class="customer-addresses__header">
      <h1 class="customer-page__heading">{{ 'customer.addresses.title' | t | default: 'Your addresses' }}</h1>
      <a href="{{ routes.account_url }}" class="customer-page__link">
        &larr; {{ 'customer.account.return' | t | default: 'Back to account' }}
      </a>
    </div>

    <div class="customer-addresses__new">
      <h2 class="customer-page__subheading">{{ 'customer.addresses.add_new' | t | default: 'Add a new address' }}</h2>
      {%- form 'customer_address', customer.new_address -%}
        {%- if form.errors -%}
          <div class="customer-page__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="customer-addresses__form-grid">
          <div class="customer-page__field">
            <label class="customer-page__label" for="AddressFirstNameNew">
              {{ 'customer.addresses.first_name' | t | default: 'First name' }}
            </label>
            <input class="customer-page__input" type="text" id="AddressFirstNameNew" name="address[first_name]" value="{{ form.first_name }}" autocomplete="given-name">
          </div>

          <div class="customer-page__field">
            <label class="customer-page__label" for="AddressLastNameNew">
              {{ 'customer.addresses.last_name' | t | default: 'Last name' }}
            </label>
            <input class="customer-page__input" type="text" id="AddressLastNameNew" name="address[last_name]" value="{{ form.last_name }}" autocomplete="family-name">
          </div>

          <div class="customer-page__field customer-addresses__field--full">
            <label class="customer-page__label" for="AddressCompanyNew">
              {{ 'customer.addresses.company' | t | default: 'Company' }}
            </label>
            <input class="customer-page__input" type="text" id="AddressCompanyNew" name="address[company]" value="{{ form.company }}" autocomplete="organization">
          </div>

          <div class="customer-page__field customer-addresses__field--full">
            <label class="customer-page__label" for="AddressAddress1New">
              {{ 'customer.addresses.address1' | t | default: 'Address' }}
            </label>
            <input class="customer-page__input" type="text" id="AddressAddress1New" name="address[address1]" value="{{ form.address1 }}" autocomplete="address-line1">
          </div>

          <div class="customer-page__field customer-addresses__field--full">
            <label class="customer-page__label" for="AddressAddress2New">
              {{ 'customer.addresses.address2' | t | default: 'Apartment, suite, etc.' }}
            </label>
            <input class="customer-page__input" type="text" id="AddressAddress2New" name="address[address2]" value="{{ form.address2 }}" autocomplete="address-line2">
          </div>

          <div class="customer-page__field">
            <label class="customer-page__label" for="AddressCityNew">
              {{ 'customer.addresses.city' | t | default: 'City' }}
            </label>
            <input class="customer-page__input" type="text" id="AddressCityNew" name="address[city]" value="{{ form.city }}" autocomplete="address-level2">
          </div>

          <div class="customer-page__field">
            <label class="customer-page__label" for="AddressCountryNew">
              {{ 'customer.addresses.country' | t | default: 'Country' }}
            </label>
            <select class="customer-page__input" id="AddressCountryNew" name="address[country]" autocomplete="country">
              {{ all_country_option_tags }}
            </select>
          </div>

          <div class="customer-page__field">
            <label class="customer-page__label" for="AddressProvinceNew">
              {{ 'customer.addresses.province' | t | default: 'State / Province' }}
            </label>
            <select class="customer-page__input" id="AddressProvinceNew" name="address[province]" autocomplete="address-level1">
              <option value="">{{ 'customer.addresses.province_select' | t | default: 'Select' }}</option>
            </select>
          </div>

          <div class="customer-page__field">
            <label class="customer-page__label" for="AddressZipNew">
              {{ 'customer.addresses.zip' | t | default: 'ZIP / Postal code' }}
            </label>
            <input class="customer-page__input" type="text" id="AddressZipNew" name="address[zip]" value="{{ form.zip }}" autocomplete="postal-code">
          </div>

          <div class="customer-page__field">
            <label class="customer-page__label" for="AddressPhoneNew">
              {{ 'customer.addresses.phone' | t | default: 'Phone' }}
            </label>
            <input class="customer-page__input" type="tel" id="AddressPhoneNew" name="address[phone]" value="{{ form.phone }}" autocomplete="tel">
          </div>

          <div class="customer-addresses__field--full">
            <label class="customer-addresses__default-label">
              <input type="checkbox" name="address[default]" value="1" id="AddressDefaultNew">
              {{ 'customer.addresses.set_default' | t | default: 'Set as default address' }}
            </label>
          </div>
        </div>

        <button type="submit" class="button button--primary">
          {{ 'customer.addresses.add' | t | default: 'Add address' }}
        </button>
      {%- endform -%}
    </div>

    {% if customer.addresses_count > 0 %}
      <hr class="customer-addresses__divider">
      <h2 class="customer-page__subheading">{{ 'customer.addresses.saved_addresses' | t | default: 'Saved addresses' }}</h2>

      <div class="customer-addresses__list">
        {% for address in customer.addresses %}
          <div class="customer-addresses__card">
            <p class="customer-addresses__card-name">
              {{ address.name }}
              {% if address == customer.default_address %}
                <span class="customer-addresses__default-badge">{{ 'customer.addresses.default' | t | default: 'Default' }}</span>
              {% endif %}
            </p>
            <address class="customer-addresses__card-address">
              {{ address.address1 }}<br>
              {% if address.address2 != blank %}{{ address.address2 }}<br>{% endif %}
              {{ address.city }}, {% if address.province != blank %}{{ address.province }}, {% endif %}{{ address.zip }}<br>
              {{ address.country }}
              {% if address.phone != blank %}<br>{{ address.phone }}{% endif %}
            </address>

            <div class="customer-addresses__card-actions">
              <button
                type="button"
                class="button button--secondary customer-addresses__edit-btn"
                aria-expanded="false"
                aria-controls="EditAddress_{{ address.id }}"
                data-address-toggle="{{ address.id }}"
              >
                {{ 'customer.addresses.edit' | t | default: 'Edit' }}
              </button>

              {%- form 'customer_address', address, id: 'delete_address_' | append: address.id -%}
                <input type="hidden" name="_method" value="delete">
                <button
                  type="submit"
                  class="button button--secondary customer-addresses__delete-btn"
                  onclick="return confirm('{{ 'customer.addresses.delete_confirm' | t | default: 'Are you sure you want to delete this address?' | escape }}')"
                >
                  {{ 'customer.addresses.delete' | t | default: 'Delete' }}
                </button>
              {%- endform -%}
            </div>

            <div id="EditAddress_{{ address.id }}" class="customer-addresses__edit-form" hidden>
              {%- form 'customer_address', address -%}
                <div class="customer-addresses__form-grid">
                  <div class="customer-page__field">
                    <label class="customer-page__label" for="AddressFirstName_{{ address.id }}">{{ 'customer.addresses.first_name' | t | default: 'First name' }}</label>
                    <input class="customer-page__input" type="text" id="AddressFirstName_{{ address.id }}" name="address[first_name]" value="{{ address.first_name }}" autocomplete="given-name">
                  </div>
                  <div class="customer-page__field">
                    <label class="customer-page__label" for="AddressLastName_{{ address.id }}">{{ 'customer.addresses.last_name' | t | default: 'Last name' }}</label>
                    <input class="customer-page__input" type="text" id="AddressLastName_{{ address.id }}" name="address[last_name]" value="{{ address.last_name }}" autocomplete="family-name">
                  </div>
                  <div class="customer-page__field customer-addresses__field--full">
                    <label class="customer-page__label" for="AddressAddress1_{{ address.id }}">{{ 'customer.addresses.address1' | t | default: 'Address' }}</label>
                    <input class="customer-page__input" type="text" id="AddressAddress1_{{ address.id }}" name="address[address1]" value="{{ address.address1 }}" autocomplete="address-line1">
                  </div>
                  <div class="customer-page__field customer-addresses__field--full">
                    <label class="customer-page__label" for="AddressAddress2_{{ address.id }}">{{ 'customer.addresses.address2' | t | default: 'Apartment, suite, etc.' }}</label>
                    <input class="customer-page__input" type="text" id="AddressAddress2_{{ address.id }}" name="address[address2]" value="{{ address.address2 }}" autocomplete="address-line2">
                  </div>
                  <div class="customer-page__field">
                    <label class="customer-page__label" for="AddressCity_{{ address.id }}">{{ 'customer.addresses.city' | t | default: 'City' }}</label>
                    <input class="customer-page__input" type="text" id="AddressCity_{{ address.id }}" name="address[city]" value="{{ address.city }}" autocomplete="address-level2">
                  </div>
                  <div class="customer-page__field">
                    <label class="customer-page__label" for="AddressCountry_{{ address.id }}">{{ 'customer.addresses.country' | t | default: 'Country' }}</label>
                    <select class="customer-page__input" id="AddressCountry_{{ address.id }}" name="address[country]" autocomplete="country">
                      {{ all_country_option_tags }}
                    </select>
                  </div>
                  <div class="customer-page__field">
                    <label class="customer-page__label" for="AddressProvince_{{ address.id }}">{{ 'customer.addresses.province' | t | default: 'State / Province' }}</label>
                    <select class="customer-page__input" id="AddressProvince_{{ address.id }}" name="address[province]" autocomplete="address-level1">
                      <option value="">{{ 'customer.addresses.province_select' | t | default: 'Select' }}</option>
                    </select>
                  </div>
                  <div class="customer-page__field">
                    <label class="customer-page__label" for="AddressZip_{{ address.id }}">{{ 'customer.addresses.zip' | t | default: 'ZIP / Postal code' }}</label>
                    <input class="customer-page__input" type="text" id="AddressZip_{{ address.id }}" name="address[zip]" value="{{ address.zip }}" autocomplete="postal-code">
                  </div>
                  <div class="customer-page__field">
                    <label class="customer-page__label" for="AddressPhone_{{ address.id }}">{{ 'customer.addresses.phone' | t | default: 'Phone' }}</label>
                    <input class="customer-page__input" type="tel" id="AddressPhone_{{ address.id }}" name="address[phone]" value="{{ address.phone }}" autocomplete="tel">
                  </div>
                  <div class="customer-addresses__field--full">
                    <label class="customer-addresses__default-label">
                      <input type="checkbox" name="address[default]" value="1" id="AddressDefault_{{ address.id }}" {% if address == customer.default_address %}checked{% endif %}>
                      {{ 'customer.addresses.set_default' | t | default: 'Set as default address' }}
                    </label>
                  </div>
                </div>
                <div class="customer-addresses__edit-actions">
                  <button type="submit" class="button button--primary">{{ 'customer.addresses.update' | t | default: 'Update address' }}</button>
                  <button type="button" class="button button--secondary" data-address-toggle="{{ address.id }}">{{ 'customer.addresses.cancel' | t | default: 'Cancel' }}</button>
                </div>
              {%- endform -%}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<script>
  document.querySelectorAll('[data-address-toggle]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var id = btn.getAttribute('data-address-toggle');
      var panel = document.getElementById('EditAddress_' + id);
      if (!panel) return;
      var isHidden = panel.hidden;
      panel.hidden = !isHidden;
      btn.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
    });
  });
</script>

<style>
  .customer-addresses__inner {
    max-width: 820px !important;
  }

  .customer-addresses__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .customer-addresses__form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 20px;
  }

  @media (max-width: 600px) {
    .customer-addresses__form-grid {
      grid-template-columns: 1fr;
    }
  }

  .customer-addresses__field--full {
    grid-column: 1 / -1;
  }

  .customer-addresses__divider {
    border: none;
    border-top: 1px solid color-mix(in srgb, var(--color-foreground, #333) 12%, transparent);
  }

  .customer-addresses__list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .customer-addresses__card {
    padding: 20px;
    border: 1px solid color-mix(in srgb, var(--color-foreground, #333) 12%, transparent);
    border-radius: var(--style-border-radius-theme, 4px);
    display: grid;
    gap: 12px;
  }

  .customer-addresses__card-name {
    font-weight: 600;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .customer-addresses__default-badge {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 8px;
    border-radius: 99px;
    background: color-mix(in srgb, var(--color-foreground, #333) 10%, transparent);
  }

  .customer-addresses__card-address {
    font-style: normal;
    font-size: 0.9rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-foreground, #333) 70%, transparent);
    margin: 0;
  }

  .customer-addresses__card-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .customer-addresses__edit-form {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid color-mix(in srgb, var(--color-foreground, #333) 12%, transparent);
    grid-column: 1 / -1;
  }

  .customer-addresses__edit-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .customer-addresses__default-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    cursor: pointer;
  }
</style>

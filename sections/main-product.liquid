{% comment %}
  Premium product page composed from a media gallery and block-driven product info.
{% endcomment %}

{{ 'product-page.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-page.js' | asset_url }}" defer></script>

{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign lower_zone_types = 'text,image' | split: ','
  assign default_related_heading = 'product.related_products' | t
  assign related_heading = section.settings.related_heading | default: default_related_heading
%}

<section
  class="product-shell section-{{ section.id }}"
  data-product-section
  data-section-id="{{ section.id }}"
  data-product-url="{{ product.url }}"
  data-add-to-cart-label="{{ 'product.add_to_cart' | t }}"
  data-sold-out-label="{{ 'product.sold_out' | t }}"
  data-unavailable-label="{{ 'product.unavailable' | t }}"
  data-available-to-order-label="{{ 'product.inventory.available_to_order' | t }}"
  data-in-stock-template="{{ 'product.inventory.in_stock_count' | t: count: '[[count]]' }}"
  data-sku-template="{{ 'product.sku' | t: value: '[[value]]' }}"
  style="
    --product-info-fr: {{ section.settings.desktop_info_width }}fr;
    --product-gallery-fr: {{ 100 | minus: section.settings.desktop_info_width }}fr;
    --product-gallery-media-fit: {{ section.settings.gallery_media_fit }};
  "
>
  <script type="application/json" data-product-json>
    {{ product | json }}
  </script>

  {% comment %} schema.org/Product rich result for Google Search {% endcomment %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "url": {{ shop.url | append: product.url | json }},
      "description": {{ product.description | strip_html | truncate: 5000 | json }},
      {% if product.featured_image %}
      "image": {{ product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }},
      {% endif %}
      {% if product.vendor != blank %}
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | json }}
      },
      {% endif %}
      "offers": [
        {% for variant in product.variants %}
        {
          "@type": "Offer",
          "name": {{ variant.title | json }},
          "sku": {{ variant.sku | json }},
          "price": {{ variant.price | divided_by: 100.0 | json }},
          "priceCurrency": {{ cart.currency.iso_code | json }},
          "availability": {% if variant.available %}"https://schema.org/InStock"{% else %}"https://schema.org/OutOfStock"{% endif %},
          "url": {{ shop.url | append: product.url | append: '?variant=' | append: variant.id | json }}
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }
  </script>

  <div class="product-shell__grid">
    <div class="product-shell__gallery-column product-shell__gallery-column--sticky">
      {% render 'product-gallery', product: product, section: section, current_variant: current_variant %}
    </div>

    <div class="product-shell__info-column {% if section.settings.enable_sticky_info %}product-shell__info-column--sticky{% endif %}">
      {% render 'product-info', product: product, section: section, current_variant: current_variant, placement: 'info' %}
    </div>
  </div>

  {% assign has_lower_content = false %}
  {% for block in section.blocks %}
    {% if lower_zone_types contains block.type and block.settings.placement == 'below_gallery' %}
      {% assign has_lower_content = true %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if has_lower_content %}
    <div class="product-shell__lower-zone">
      <div class="product-shell__lower-zone-inner">
        {% render 'product-info', product: product, section: section, current_variant: current_variant, placement: 'below_gallery' %}
      </div>
    </div>
  {% endif %}

  {% if section.settings.show_related_products %}
    {% assign related_products = product.related_products | default: recommendations.products %}
    {% if related_products != blank %}
      <div class="product-shell__related">
        <div class="product-shell__related-header">
          <h2>{{ related_heading }}</h2>
        </div>
        <div class="product-shell__related-grid">
          {% for related_product in related_products limit: section.settings.related_count %}
            <article class="product-shell__related-card">
              <a href="{{ related_product.url }}" class="product-shell__related-link">
                <div class="product-shell__related-media">
                  {% if related_product.featured_image %}
                    {{
                      related_product.featured_image
                      | image_url: width: 800
                      | image_tag: loading: 'lazy', class: 'product-shell__related-image', widths: '200, 300, 400, 600, 800', sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw'
                    }}
                  {% endif %}
                </div>
                <div class="product-shell__related-content">
                  <p class="product-shell__related-title">{{ related_product.title }}</p>
                  <p class="product-shell__related-price">
                    {{ related_product.price | money_with_currency }}
                  </p>
                </div>
              </a>
            </article>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  {% endif %}
</section>


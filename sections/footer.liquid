      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Customer care"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Questions about sizing, shipping, or an order already on the way? Reach out and we will help.</p>"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Contact email",
          "default": "hello@example.com"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Contact phone",
          "default": "+31 20 123 4567"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Hours"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p><strong>Monday to Friday:</strong> 9:00 - 18:00<br><strong>Saturday:</strong> 10:00 - 17:00<br><strong>Sunday:</strong> Closed</p>"
        }
      ]
    }
  ]
}
{% endschema %}

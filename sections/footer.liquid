          "label": "Arrow button inside field",
          "info": "Shows the submit button as an arrow inside the input instead of a separate button.",
          "default": false
        },
        {
          "type": "text",
          "id": "note",
          "label": "Note",
          "default": "A calm, occasional edit. Unsubscribe whenever you like."
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "Open accordion by default on mobile",
          "default": true
        }
      ]
    },
    {
      "type": "contact",

{% style %}
  #shopify-section-{{ section.id }} {
    --heading-scale: {{ section.settings.heading_font_scale | default: 100 | divided_by: 100.0 }};
    --body-scale: {{ section.settings.body_font_scale | default: 100 | divided_by: 100.0 }};
  }
{% endstyle %}
{% liquid
  assign heading = section.settings.heading | strip
  assign subheading = section.settings.subheading | strip
%}
{% render 'color-scheme', color_scheme: section.settings.color_scheme, section_id: section.id %}
<section
  class="trust-points{% if section.settings.show_section_divider %} trust-points--divider{% endif %}"
  style="
    background-color: var(--color-background);
    color: var(--color-foreground);
    --trust-points-padding-top: 32px;
    --trust-points-padding-bottom: 32px;
  "
>
  <div class="trust-points__inner">
    {% if subheading != blank or heading != blank %}
      <div class="trust-points__header">
        {% if subheading != blank %}
          <p class="trust-points__subheading">{{ subheading }}</p>
        {% endif %}
        {% if heading != blank %}
          <h2 class="trust-points__heading">{{ heading }}</h2>
        {% endif %}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="trust-points__list" role="list" data-trust-scroll>
        {% for block in section.blocks %}
          <article class="trust-points__item" role="listitem" {{ block.shopify_attributes }}>
            <div class="trust-points__icon" aria-hidden="true" style="--trust-points-icon-size: {{ block.settings.icon_size }}px;">
              {% if block.settings.custom_icon != blank %}
                {{
                  block.settings.custom_icon
                  | image_url: width: 120
                  | image_tag:
                    class: 'trust-points__icon-image',
                    widths: '40, 60, 80, 120',
                    loading: 'lazy'
                }}
              {% else %}
                {% case block.settings.icon %}
                  {% when 'shipping' %}
                    <svg viewBox="0 0 50 50" focusable="false" role="presentation">
                      <path d="M0 8v2h28.09c.4 0 .91.51.91.91V38H18.91C18.43 35.16 15.96 33 13 33S7.57 35.16 7.09 38H3c-.55 0-1-.45-1-1V28H0v9c0 1.64 1.36 3 3 3h4.09C7.57 42.84 10.04 45 13 45s5.43-2.16 5.91-5h15.18c.48 2.84 2.95 5 5.91 5s5.43-2.16 5.91-5H47c.83 0 1.56-.38 2.09-.91.53-.53.91-1.26.91-2.09V27.41c0-1.13-.43-2.16-.81-2.94-.38-.78-.78-1.34-.78-1.34v-.03l-4.09-5.5-.03-.03v-.03C43.39 16.45 41.97 15 40 15h-8c-.36 0-.69.07-1 .19v-4.28C31 9.3 29.7 8 28.09 8H0Zm0 4v2h18v-2H0Zm0 4v2h15v-2H0Zm32 1h4v9c0 .83.38 1.56.91 2.09.53.53 1.26.91 2.09.91h9v8c0 .17-.13.44-.34.66-.22.22-.49.34-.66.34h-1.09C45.43 35.16 42.96 33 40 33s-5.43 2.16-5.91 5H31V18c0-.17.13-.44.34-.66.22-.22.49-.34.66-.34Zm6 0h2c.82 0 1.97.93 2.69 1.81l4.09 5.47.03.03c.02.03.29.41.59 1.03.25.52.39 1.13.47 1.66H39c-.17 0-.44-.13-.66-.34-.22-.22-.34-.49-.34-.66v-9ZM0 20v2h12v-2H0Zm0 4v2h9v-2H0Zm13 11c2.22 0 4 1.78 4 4s-1.78 4-4 4-4-1.78-4-4 1.78-4 4-4Zm27 0c2.22 0 4 1.78 4 4s-1.78 4-4 4-4-1.78-4-4 1.78-4 4-4Z" fill="currentColor"></path>
                    </svg>
                  {% when 'return' %}
                    <svg viewBox="0 0 50 50" focusable="false" role="presentation">
                      <path d="M25 2C12.31 2 2 12.31 2 25s10.31 23 23 23c7.29 0 13.79-3.4 18-8.7V47a1 1 0 1 0 2 0V36h-1.51L43.39 36H34a1 1 0 1 0 0 2h7.48C37.64 42.87 31.69 46 25 46 13.39 46 4 36.61 4 25S13.39 4 25 4s21 9.39 21 21a1 1 0 1 0 2 0C48 12.31 37.69 2 25 2Zm-.02 6.99A1 1 0 0 0 24 10v12.18a3 3 0 0 0 1 5.82A3 3 0 0 0 27.83 26H36a1 1 0 1 0 0-2h-8.17A3 3 0 0 0 26 22.17V10a1 1 0 0 0-1.02-1.01Z" fill="currentColor"></path>
                    </svg>
                  {% when 'secure' %}
                    <svg viewBox="0 0 50 50" focusable="false" role="presentation">
                      <path d="M7 9C4.25 9 2 11.25 2 14v22c0 2.75 2.25 5 5 5h18l4.64 0c-.25-.63-.47-1.3-.67-2H25H7c-1.67 0-3-1.33-3-3V21H46v3v3.86c.56.23 1.21.46 2 .68V24V14c0-2.75-2.25-5-5-5H7Zm0 2h36c1.67 0 3 1.33 3 3v2H4v-2c0-1.67 1.33-3 3-3Zm2 13v2h16v-2H9Zm31 3.9c-1.5 0-2.5.5-3.7 1.1-1.2.6-2.7 1.3-5.5 1.9L30 31.1v.8c0 13 9.2 17.7 9.5 17.9l.5.2.5-.2c.4-.2 9.5-5.3 9.5-17.9v-.8l-.8-.2c-2.8-.6-4.3-1.3-5.5-1.9-1.2-.6-2.2-1.1-3.7-1.1Zm0 2c1.1 0 1.7.3 2.8.9 1.2.5 2.7 1.3 5.2 1.9-.3 9.3-6.3 13.9-8 15-1.8-1-7.7-5.3-8-15 2.6-.6 4.1-1.4 5.2-1.9 1.1-.6 1.7-.9 2.8-.9Z" fill="currentColor"></path>
                    </svg>
                {% endcase %}
              {% endif %}
            </div>

            {% if block.settings.title != blank %}
              <h3 class="trust-points__item-title">{{ block.settings.title }}</h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <div class="trust-points__item-text rte">{{ block.settings.text }}</div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
      <div class="trust-points__scroll-track" aria-hidden="true">
        <div class="trust-points__scroll-fill"></div>
      </div>
    {% endif %}
  </div>
</section>

<script>
  (function() {
    var list = document.querySelector('[data-trust-scroll]');
    var fill = list && list.parentElement && list.parentElement.querySelector('.trust-points__scroll-fill');
    if (!list || !fill) return;

    function update() {
      var max = list.scrollWidth - list.clientWidth;
      fill.style.width = max > 0 ? Math.round((list.scrollLeft / max) * 100) + '%' : '33%';
    }

    list.addEventListener('scroll', update, { passive: true });
    update();
  })();
</script>

{% stylesheet %}
  .trust-points {
    padding: var(--trust-points-padding-top) 0 var(--trust-points-padding-bottom);
  }

  .trust-points--divider {
    border-top: 1px solid color-mix(in srgb, var(--color-foreground) 10%, transparent);
  }

  .trust-points__inner {
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    margin: 0 auto;
  }

  .trust-points__header {
    display: grid;
    gap: 10px;
    margin-bottom: 24px;
    text-align: center;
  }

  .trust-points__subheading {
    margin: 0;
    font-size: calc(0.78rem * var(--body-scale, 1));
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.68;
  }

  .trust-points__heading {
    margin: 0;
    font-size: calc(clamp(1.8rem, 3vw, 2.8rem) * var(--heading-scale, 1));
    line-height: 1;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .trust-points__list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 24px;
  }

  .trust-points__item {
    display: grid;
    justify-items: center;
    gap: 12px;
    padding: 8px 12px;
    text-align: center;
  }

  .trust-points__icon {
    width: var(--trust-points-icon-size, 30px);
    height: var(--trust-points-icon-size, 30px);
    color: currentColor;
  }

  .trust-points__icon svg,
  .trust-points__icon-image {
    width: 100%;
    height: 100%;
  }

  .trust-points__icon-image {
    object-fit: contain;
  }

  .trust-points__item-title {
    margin: 0;
    font-size: calc(1rem * var(--heading-scale, 1));
    line-height: 1.2;
  }

  .trust-points__item-text {
    max-width: 34ch;
    font-size: calc(0.92rem * var(--body-scale, 1));
    line-height: 1.45;
    color: color-mix(in srgb, var(--color-foreground) 78%, transparent);
  }

  .trust-points__item-text > *:first-child {
    margin-top: 0;
  }

  .trust-points__item-text > *:last-child {
    margin-bottom: 0;
  }

  .trust-points__scroll-track {
    display: none;
  }

  @media (max-width: 989px) {
    .trust-points__list {
      grid-auto-flow: column;
      grid-auto-columns: minmax(84%, 1fr);
      grid-template-columns: none;
      gap: 16px;
      overflow-x: auto;
      padding-bottom: 6px;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }

    .trust-points__list::-webkit-scrollbar {
      display: none;
    }

    .trust-points__item {
      min-height: 100%;
      padding: 20px 18px;
      scroll-snap-align: start;
    }

    .trust-points__scroll-track {
      display: block;
      height: 3px;
      margin-top: 14px;
      background: color-mix(in srgb, var(--color-foreground) 12%, transparent);
      border-radius: 999px;
      overflow: hidden;
    }

    .trust-points__scroll-fill {
      height: 100%;
      background: var(--color-foreground);
      border-radius: 999px;
      width: 33%;
      transition: width 0.1s linear;
    }
  }

  @media (max-width: 749px) {
    .trust-points {
      padding: 24px 0;
    }

    .trust-points__header {
      margin-bottom: 18px;
    }

    .trust-points__item-title {
      font-size: calc(0.95rem * var(--heading-scale, 1));
    }

    .trust-points__item-text {
      font-size: calc(0.88rem * var(--body-scale, 1));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trust points",
  "tag": "section",
  "class": "section-trust-points",
  "settings": [
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_scale",
      "label": "Heading font size",
      "min": 60,
      "max": 160,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "body_font_scale",
      "label": "Body font size",
      "min": 60,
      "max": 160,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "show_section_divider",
      "label": "Show section divider",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {
              "value": "shipping",
              "label": "Shipping"
            },
            {
              "value": "return",
              "label": "Return"
            },
            {
              "value": "secure",
              "label": "Secure payment"
            }
          ],
          "default": "shipping"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom icon"
        },
        {
          "type": "range",
          "id": "icon_size",
          "label": "Icon size",
          "min": 20,
          "max": 56,
          "step": 2,
          "unit": "px",
          "default": 30
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free shipping"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Share one clear supporting point for the store.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust points",
      "blocks": [
        {
          "type": "point",
          "settings": {
            "icon": "shipping",
            "title": "Free Shipping",
            "text": "<p>We offer free shipping for maximum customer comfort. Your satisfaction is important to us, which is why we offer smooth and free delivery.</p>"
          }
        },
        {
          "type": "point",
          "settings": {
            "icon": "return",
            "title": "30-Day Return Guarantee",
            "text": "<p>Your satisfaction is our focus. Our 30-day return policy guarantees you maximum flexibility and the best shopping experience.</p>"
          }
        },
        {
          "type": "point",
          "settings": {
            "icon": "secure",
            "title": "100% Secure Payment",
            "text": "<p>We offer a variety of secure payment options. Pay easily and enjoy a safe shopping experience.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

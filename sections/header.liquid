{% style %}
  #shopify-section-{{ section.id }} {
    --heading-scale: {{ section.settings.heading_font_scale | default: 100 | divided_by: 100.0 }};
    --body-scale: {{ section.settings.body_font_scale | default: 100 | divided_by: 100.0 }};
  }
{% endstyle %}
{{ 'predictive-search.css' | asset_url | stylesheet_tag }}
{% liquid
  assign overlay_header = false
  assign header_layout = section.settings.header_layout | default: 'logo-left-menu-center'
  assign header_style = section.settings.header_style | default: 'sticky'
  assign logo_width = section.settings.logo_width | default: 160
  assign mobile_menu_title = section.settings.mobile_menu_title | default: 'Menu'

  if request.page_type == 'index' and section.settings.overlay_homepage
    assign overlay_header = true
  endif

  if request.page_type == 'collection' and section.settings.overlay_collection
    assign overlay_header = true
  endif

  assign menu_links = section.settings.menu.links
  assign split_index = 0
  assign logo_style = '--logo-width: ' | append: logo_width | append: 'px;'

  assign header_density = section.settings.header_density | default: 'normal'
  assign header_row_height = '4.5rem'
  assign header_inner_padding = '1rem'
  if header_density == 'slim'
    assign header_row_height = '3.25rem'
    assign header_inner_padding = '0.4rem'
  endif

  if menu_links != blank
    assign split_index = menu_links.size | plus: 1 | divided_by: 2
  endif

  assign show_language_selector = false
  if section.settings.show_language_selector and localization.available_languages.size > 1
    assign show_language_selector = true
  endif

  assign show_currency_selector = false
  if section.settings.show_currency_selector and localization.available_countries.size > 1
    assign show_currency_selector = true
  endif
%}

{% capture logo_markup %}
  {% if section.settings.logo != blank %}
    {{
      section.settings.logo
      | image_url: width: 600
      | image_tag:
        class: 'header__logo-image',
        widths: '120, 160, 200, 240, 320, 400, 480, 600',
        style: logo_style
    }}
  {% else %}
    <span class="header__logo-text">{{ shop.name }}</span>
  {% endif %}
{% endcapture %}

{% capture menu_markup %}
  {% if menu_links != blank %}
    <nav class="header__nav" aria-label="Primary">
      <ul class="header__menu-list" role="list">
        {% for link in menu_links %}
          <li class="header__menu-item{% if link.links != blank %} has-dropdown{% endif %}">
            {% if link.links != blank %}
              <details class="header__menu-disclosure" data-header-disclosure data-hover-enabled="{{ section.settings.enable_dropdown_hover }}">
                <summary class="header__menu-link">
                  <span>{{ link.title }}</span>
                  <span class="header__menu-caret" aria-hidden="true"></span>
                </summary>
                <div class="header__submenu">
                  <ul role="list">
                    <li>
                      <a href="{{ link.url }}" class="header__submenu-link header__submenu-link--parent">
                        <span>{{ link.title }}</span>
                      </a>
                    </li>
                    {% for child_link in link.links %}
                      <li>
                        <a href="{{ child_link.url }}" class="header__submenu-link">
                          <span>{{ child_link.title }}</span>
                          {% if section.settings.show_mega_menu_images and child_link.object.featured_image != blank %}
                            {{
                              child_link.object.featured_image
                              | image_url: width: 220
                              | image_tag:
                                class: 'header__submenu-image',
                                widths: '120, 160, 220'
                            }}
                          {% endif %}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </details>
            {% else %}
              <a href="{{ link.url }}" class="header__menu-link">
                <span>{{ link.title }}</span>
                {% if link.links != blank %}
                  <span class="header__menu-caret" aria-hidden="true"></span>
                {% endif %}
              </a>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>
  {% endif %}
{% endcapture %}

{% capture split_menu_left %}
  {% if menu_links != blank %}
    <nav class="header__nav" aria-label="Primary left">
      <ul class="header__menu-list" role="list">
        {% for link in menu_links limit: split_index %}
          <li class="header__menu-item{% if link.links != blank %} has-dropdown{% endif %}">
            {% if link.links != blank %}
              <details class="header__menu-disclosure" data-header-disclosure data-hover-enabled="{{ section.settings.enable_dropdown_hover }}">
                <summary class="header__menu-link">
                  <span>{{ link.title }}</span>
                  <span class="header__menu-caret" aria-hidden="true"></span>
                </summary>
                <div class="header__submenu">
                  <ul role="list">
                    <li>
                      <a href="{{ link.url }}" class="header__submenu-link header__submenu-link--parent">
                        <span>{{ link.title }}</span>
                      </a>
                    </li>
                    {% for child_link in link.links %}
                      <li>
                        <a href="{{ child_link.url }}" class="header__submenu-link">
                          <span>{{ child_link.title }}</span>
                          {% if section.settings.show_mega_menu_images and child_link.object.featured_image != blank %}
                            {{
                              child_link.object.featured_image
                              | image_url: width: 220
                              | image_tag:
                                class: 'header__submenu-image',
                                widths: '120, 160, 220'
                            }}
                          {% endif %}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </details>
            {% else %}
              <a href="{{ link.url }}" class="header__menu-link">{{ link.title }}</a>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>
  {% endif %}
{% endcapture %}

{% capture split_menu_right %}
  {% if menu_links != blank %}
    <nav class="header__nav header__nav--right" aria-label="Primary right">
      <ul class="header__menu-list" role="list">
        {% for link in menu_links offset: split_index %}
          <li class="header__menu-item{% if link.links != blank %} has-dropdown{% endif %}">
            {% if link.links != blank %}
              <details class="header__menu-disclosure" data-header-disclosure data-hover-enabled="{{ section.settings.enable_dropdown_hover }}">
                <summary class="header__menu-link">
                  <span>{{ link.title }}</span>
                  <span class="header__menu-caret" aria-hidden="true"></span>
                </summary>
                <div class="header__submenu">
                  <ul role="list">
                    <li>
                      <a href="{{ link.url }}" class="header__submenu-link header__submenu-link--parent">
                        <span>{{ link.title }}</span>
                      </a>
                    </li>
                    {% for child_link in link.links %}
                      <li>
                        <a href="{{ child_link.url }}" class="header__submenu-link">
                          <span>{{ child_link.title }}</span>
                          {% if section.settings.show_mega_menu_images and child_link.object.featured_image != blank %}
                            {{
                              child_link.object.featured_image
                              | image_url: width: 220
                              | image_tag:
                                class: 'header__submenu-image',
                                widths: '120, 160, 220'
                            }}
                          {% endif %}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </details>
            {% else %}
              <a href="{{ link.url }}" class="header__menu-link">{{ link.title }}</a>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>
  {% endif %}
{% endcapture %}

{% capture drawer_markup %}
  {% if menu_links != blank %}
    <details class="header__drawer{% if header_layout == 'logo-center-menu-drawer' %} header__drawer--left{% else %} header__drawer--right{% endif %}" data-header-drawer>
      <summary class="header__drawer-toggle" aria-label="{{ mobile_menu_title | escape }}" data-header-drawer-toggle>
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div
        class="header__drawer-panel"
        data-header-drawer-panel
        role="dialog"
        aria-modal="true"
        aria-label="{{ mobile_menu_title | escape }}"
        tabindex="-1"
      >
        <div class="header__drawer-header">
          <p class="header__drawer-title">{{ mobile_menu_title }}</p>
          <button type="button" class="header__drawer-close" data-header-drawer-close aria-label="{{ 'general.close' | t }}">
            {{ 'general.close' | t }}
          </button>
        </div>
        <ul class="header__drawer-list" role="list">
          {% for link in menu_links %}
            <li>
              {% if link.links != blank %}
                <details class="header__drawer-nested">
                  <summary>{{ link.title }}</summary>
                  <ul role="list">
                    {% for child_link in link.links %}
                      <li><a href="{{ child_link.url }}">{{ child_link.title }}</a></li>
                    {% endfor %}
                  </ul>
                </details>
              {% else %}
                <a href="{{ link.url }}">{{ link.title }}</a>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
        {% if show_language_selector or show_currency_selector %}
          <div class="header__drawer-localization">
            <div class="header__localization header__localization--drawer">
              {% form 'localization', class: 'header__localization-forms' %}
                {% if show_language_selector %}
                  <details class="header__picker">
                    <summary>
                      <span>{{ localization.language.endonym_name | capitalize }}</span>
                    </summary>
                    <div class="header__picker-menu">
                      {% for language in localization.available_languages %}
                        <button type="submit" name="locale_code" value="{{ language.iso_code }}" class="header__picker-option">
                          {{ language.endonym_name | capitalize }}
                        </button>
                      {% endfor %}
                    </div>
                  </details>
                {% endif %}

                {% if show_currency_selector %}
                  <details class="header__picker">
                    <summary>
                      <span>{{ localization.country.currency.iso_code }}</span>
                    </summary>
                    <div class="header__picker-menu">
                      {% for country in localization.available_countries %}
                        <button type="submit" name="country_code" value="{{ country.iso_code }}" class="header__picker-option">
                          {% if section.settings.show_currency_flags %}
                            <span class="header__country-flag" aria-hidden="true">
                              {{ country.iso_code | slice: 0, 1 }}
                              {{ country.iso_code | slice: 1, 1 }}
                            </span>
                          {% endif %}
                          <span>{{ country.name }}</span>
                          <span>{{ country.currency.iso_code }} {{ country.currency.symbol }}</span>
                        </button>
                      {% endfor %}
                    </div>
                  </details>
                {% endif %}
              {% endform %}
            </div>
          </div>
        {% endif %}
      </div>
    </details>
  {% endif %}
{% endcapture %}

{% capture localization_markup %}
  {% if show_language_selector or show_currency_selector %}
    <div class="header__localization">
      {% form 'localization', class: 'header__localization-forms' %}
        {% if show_language_selector %}
          <details class="header__picker">
            <summary>
              <span>{{ localization.language.endonym_name | capitalize }}</span>
            </summary>
            <div class="header__picker-menu">
              {% for language in localization.available_languages %}
                <button type="submit" name="locale_code" value="{{ language.iso_code }}" class="header__picker-option">
                  {{ language.endonym_name | capitalize }}
                </button>
              {% endfor %}
            </div>
          </details>
        {% endif %}

        {% if show_currency_selector %}
          <details class="header__picker">
            <summary>
              <span>{{ localization.country.currency.iso_code }}</span>
            </summary>
            <div class="header__picker-menu">
              {% for country in localization.available_countries %}
                <button type="submit" name="country_code" value="{{ country.iso_code }}" class="header__picker-option">
                  {% if section.settings.show_currency_flags %}
                    <span class="header__country-flag" aria-hidden="true">
                      {{ country.iso_code | slice: 0, 1 }}
                      {{ country.iso_code | slice: 1, 1 }}
                    </span>
                  {% endif %}
                  <span>{{ country.name }}</span>
                  <span>{{ country.currency.iso_code }} {{ country.currency.symbol }}</span>
                </button>
              {% endfor %}
            </div>
          </details>
        {% endif %}
      {% endform %}
    </div>
  {% endif %}
{% endcapture %}

{% capture icons_markup %}
  <div class="header__icons">
    {% if section.settings.show_account_icon and shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    {% if section.settings.show_search_icon %}
      <details class="header__search" data-header-search>
        <summary class="header__search-toggle" aria-label="{{ 'search.title' | t }}">
          <span class="visually-hidden">{{ 'search.title' | t }}</span>
          <svg aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 20 20" fill="none">
            <circle cx="9" cy="9" r="4.5" stroke="currentColor" stroke-width="var(--icon-stroke-width)"></circle>
            <path d="m12.4 12.4 3.1 3.1" stroke="currentColor" stroke-width="var(--icon-stroke-width)" stroke-linecap="round"></path>
          </svg>
        </summary>
        <div class="header__search-panel" role="dialog" aria-modal="false">
          <predictive-search
            class="header__predictive-search"
            data-searching-label="{{ 'search.searching' | t }}"
            data-unavailable-label="{{ 'search.unavailable' | t }}"
          >
            <form action="{{ routes.search_url }}" method="get" role="search" class="header__search-form">
              <label class="visually-hidden" for="HeaderSearch-{{ section.id }}">{{ 'search.title' | t }}</label>
              <input
                id="HeaderSearch-{{ section.id }}"
                type="search"
                name="q"
                value=""
                placeholder="{{ 'search.placeholder' | t }}"
                class="header__search-input"
                autocomplete="off"
                autocorrect="off"
                autocapitalize="off"
                spellcheck="false"
                role="combobox"
                aria-expanded="false"
                aria-controls="HeaderSearchResults-{{ section.id }}"
                aria-haspopup="listbox"
                aria-autocomplete="list"
              >
              <input name="options[prefix]" type="hidden" value="last">
              <button class="header__search-submit" type="submit">{{ 'search.submit' | t }}</button>
            </form>
            <div
              id="HeaderSearchResults-{{ section.id }}"
              class="header__search-results"
              data-predictive-search-results
              hidden
            ></div>
          </predictive-search>
        </div>
      </details>
    {% endif %}

    <a href="{{ routes.cart_url }}" aria-label="{{ 'cart.title' | t }}" data-cart-toggle>
      <sup data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</sup>
      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
{% endcapture %}

{% capture utilities_markup %}
  {{ icons_markup }}
{% endcapture %}

{% comment %}
  AJAX predictive search is temporarily disabled. The search panel still works
  as a standard full-page search (the form submits to routes.search_url).
  To re-enable live suggestions, uncomment the script below.
{% endcomment %}
{% comment %}
{% if section.settings.show_search_icon %}
  <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
{% endif %}
{% endcomment %}

{% render 'color-scheme', color_scheme: section.settings.color_scheme, section_id: section.id %}
<header
  class="header full-width header--{{ header_layout }}{% if header_style == 'sticky' %} header--sticky{% endif %}{% if overlay_header %} header--overlay{% endif %}"
  data-header-section
  style="
    --cart-badge-text-color: {{ settings.cart_drawer_badge_text_color }};
    --cart-badge-background-color: {{ settings.cart_drawer_badge_background_color }};
    --header-row-height: {{ header_row_height }};
    --header-inner-padding: {{ header_inner_padding }};
  "
>
  <div class="header__inner">
    <div class="header__mobile-row">
      <div class="header__group header__group--mobile-start">
        {{ drawer_markup }}
      </div>
      <div class="header__group header__group--mobile-center">
        <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">{{ logo_markup }}</a>
      </div>
      <div class="header__group header__group--mobile-end">
        {{ icons_markup }}
      </div>
    </div>

    <div class="header__desktop">
      {% case header_layout %}
        {% when 'logo-left-menu-center' %}
          <div class="header__desktop-row header__desktop-row--three">
            <div class="header__group header__group--start">
              <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">{{ logo_markup }}</a>
              {{ localization_markup }}
            </div>
            <div class="header__group header__group--center">
              {{ menu_markup }}
            </div>
            <div class="header__group header__group--end">
              {{ utilities_markup }}
            </div>
          </div>
        {% when 'logo-center-menu-left' %}
          <div class="header__desktop-row header__desktop-row--three">
            <div class="header__group header__group--start">
              {{ menu_markup }}
              {{ localization_markup }}
            </div>
            <div class="header__group header__group--center">
              <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">{{ logo_markup }}</a>
            </div>
            <div class="header__group header__group--end">
              {{ utilities_markup }}
            </div>
          </div>
        {% when 'logo-center-menu-below' %}
          <div class="header__desktop-stack">
            <div class="header__desktop-row header__desktop-row--three">
              <div class="header__group header__group--start">
                {{ localization_markup }}
              </div>
              <div class="header__group header__group--center">
                <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">{{ logo_markup }}</a>
              </div>
              <div class="header__group header__group--end">
                {{ icons_markup }}
              </div>
            </div>
            <div class="header__desktop-row header__desktop-row--below header__desktop-row--below-centered">
              {{ menu_markup }}
            </div>
          </div>
        {% when 'logo-center-menu-drawer' %}
          <div class="header__desktop-row header__desktop-row--three">
            <div class="header__group header__group--start">
              {{ drawer_markup }}
              {{ localization_markup }}
            </div>
            <div class="header__group header__group--center">
              <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">{{ logo_markup }}</a>
            </div>
            <div class="header__group header__group--end">
              {{ utilities_markup }}
            </div>
          </div>
        {% when 'logo-center-menu-split' %}
          <div class="header__desktop-row header__desktop-row--split">
            <div class="header__group header__group--start">
              {{ split_menu_left }}
              {{ localization_markup }}
            </div>
            <div class="header__group header__group--center">
              <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">{{ logo_markup }}</a>
            </div>
            <div class="header__group header__group--end">
              {{ split_menu_right }}
              {{ utilities_markup }}
            </div>
          </div>
      {% endcase %}
    </div>
  </div>
</header>

{% style %}
  #shopify-section-{{ section.id }} {
    position: relative;
    z-index: 30;
  }

  #shopify-section-{{ section.id }}:has(.header__search[open]) {
    z-index: 90;
  }

  #shopify-section-{{ section.id }}:has(.header--overlay) {
    height: 0;
    overflow: visible;
    position: relative;
    z-index: 30;
  }

  #shopify-section-{{ section.id }}:has(.header--sticky) {
    position: sticky;
    top: 0;
    z-index: 50;
  }

  #shopify-section-{{ section.id }} .header--sticky.header--overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
  }

  .header {
    position: relative;
    background: var(--color-background);
    border-bottom: 1px solid var(--colorBorder);
    color: var(--color-foreground);
    z-index: 30;
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }

  .header--sticky {
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .header--overlay {
    background: transparent;
    border-bottom-color: rgba(255, 255, 255, 0.18);
    backdrop-filter: none;
    color: #ffffff;
  }

  .header--overlay a,
  .header--overlay summary,
  .header--overlay shopify-account,
  .header--overlay button {
    color: inherit;
  }

  /* Once scrolled past the hero, the transparent header becomes solid so it stays readable */
  .header--overlay.is-scrolled {
    background: var(--color-background);
    border-bottom-color: var(--colorBorder);
    color: var(--color-foreground);
  }

  .header__inner {
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    margin: 0 auto;
    padding: var(--header-inner-padding, 1rem) 0;
  }

  .header__mobile-row {
    display: none;
    position: relative;
    align-items: center;
    gap: 1rem;
    min-height: var(--header-row-height, 4.5rem);
  }

  .header__desktop {
    display: block;
  }

  .header__desktop-stack {
    display: grid;
    gap: 0.75rem;
  }

  .header__desktop-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-height: var(--header-row-height, 4.5rem);
    position: relative;
  }

  .header__desktop-row--compact {
    justify-content: space-between;
  }

  .header__desktop-row--three {
    justify-content: space-between;
  }

  .header__desktop-row--split {
    justify-content: space-between;
  }

  .header__desktop-row--below {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: auto;
  }

  .header__group {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }

  .header__desktop-row--three > .header__group--start,
  .header__desktop-row--three > .header__group--end,
  .header__desktop-row--split > .header__group--start,
  .header__desktop-row--split > .header__group--end,
  .header__desktop-row--compact > .header__group--start,
  .header__desktop-row--compact > .header__group--end {
    flex: 1 1 0;
  }

  .header__group--center {
    justify-content: center;
    flex: 0 0 auto;
  }

  .header__group--end {
    justify-content: flex-end;
  }

  .header__group--combo {
    flex-wrap: wrap;
  }

  .header__group--logo-menu-inline {
    justify-content: flex-start;
    gap: 1.5rem;
  }

  .header__group--mobile-start,
  .header__group--mobile-end {
    flex: 0 0 auto;
  }

  .header__group--mobile-center {
    justify-content: center;
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
  }

  .header__group--mobile-end {
    justify-content: flex-end;
  }

  .header--logo-center-menu-left .header__desktop-row--three,
  .header--logo-center-menu-below .header__desktop-row--three,
  .header--logo-center-menu-drawer .header__desktop-row--three,
  .header--logo-center-menu-split .header__desktop-row--split {
    position: relative;
  }

  .header--logo-center-menu-left .header__group--center,
  .header--logo-center-menu-below .header__group--center,
  .header--logo-center-menu-drawer .header__group--center,
  .header--logo-center-menu-split .header__group--center {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    pointer-events: none;
  }

  .header--logo-center-menu-left .header__group--center .header__logo-link,
  .header--logo-center-menu-below .header__group--center .header__logo-link,
  .header--logo-center-menu-drawer .header__group--center .header__logo-link,
  .header--logo-center-menu-split .header__group--center .header__logo-link {
    pointer-events: auto;
  }

  .header--logo-center-menu-left .header__group--center,
  .header--logo-center-menu-below .header__group--center,
  .header--logo-center-menu-drawer .header__group--center,
  .header--logo-center-menu-split .header__group--center {
    justify-content: center;
  }


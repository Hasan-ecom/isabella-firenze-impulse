{% style %}
  #shopify-section-{{ section.id }} {
    --heading-scale: {{ section.settings.heading_font_scale | default: 100 | divided_by: 100.0 }};
    --body-scale: {{ section.settings.body_font_scale | default: 100 | divided_by: 100.0 }};
  }
{% endstyle %}
{% comment %}
  Article page section — includes Article JSON-LD for Google rich results,
  a readable editorial layout, breadcrumb back-link, and optional comments.
{% endcomment %}

{% assign article_url = shop.url | append: blog.url | append: '/' | append: article.handle %}

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ article.title | json }},
    "url": {{ article_url | json }},
    "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
    "dateModified": {{ article.updated_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
    "author": {
      "@type": "Person",
      "name": {{ article.author | json }}
    },
    "publisher": {
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }}
    }
    {% if article.image %}
    ,"image": {{ article.image | image_url: width: 1200 | prepend: 'https:' | json }}
    {% endif %}
    {% if article.excerpt != blank %}
    ,"description": {{ article.excerpt | strip_html | truncate: 300 | json }}
    {% endif %}
  }
</script>

<article class="article-page section-{{ section.id }}">
  <div class="article-page__inner">

    <nav class="article-page__breadcrumb" aria-label="{{ 'general.breadcrumb' | t }}">
      <a href="{{ blog.url }}">{{ blog.title }}</a>
      <span aria-hidden="true"> / </span>
      <span>{{ article.title }}</span>
    </nav>

    <header class="article-page__header">
      {% if article.tags.size > 0 %}
        <div class="article-page__tags" aria-label="{{ 'general.tags' | t }}">
          {% for tag in article.tags %}
            <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="article-page__tag">{{ tag }}</a>
          {% endfor %}
        </div>
      {% endif %}

      <h1 class="article-page__title">{{ article.title }}</h1>

      <p class="article-page__meta">
        {% assign date = article.published_at | time_tag: format: 'date' %}
        {{ 'blog.article_metadata_html' | t: date: date, author: article.author }}
      </p>
    </header>

    {% if article.image %}
      <div class="article-page__hero">
        {{
          article.image
          | image_url: width: 1200
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            class: 'article-page__hero-image',
            alt: article.image.alt | default: article.title,
            widths: '400, 600, 800, 1000, 1200',
            sizes: '(min-width: 1000px) 800px, 100vw'
        }}
      </div>
    {% endif %}

    <div class="article-page__body rte">
      {{ article.content }}
    </div>

    <footer class="article-page__footer">
      <a href="{{ blog.url }}" class="article-page__back-link">
        &larr; {{ blog.title }}
      </a>
    </footer>

  </div>
</article>

{% if blog.comments_enabled? %}
  <section class="article-comments section-{{ section.id }}">
    <div class="article-comments__inner">

      {% if article.comments_count > 0 %}
        <h2 class="article-comments__heading">{{ 'blog.article_comments' | t }}</h2>

        <div id="comments">
          {% paginate article.comments by 10 %}
            <ol class="article-comments__list" role="list">
              {% for comment in article.comments %}
                <li class="article-comments__item">
                  <p class="article-comments__author">{{ comment.author }}</p>
                  <p class="article-comments__date">{{ comment.created_at | time_tag: format: 'date' }}</p>
                  <div class="article-comments__body">{{ comment.content }}</div>
                </li>
              {% endfor %}
            </ol>
            {{ paginate | default_pagination: anchor: 'comments' }}
          {% endpaginate %}
        </div>
      {% endif %}

      {% form 'new_comment', article, class: 'article-comments__form' %}
        <h2 class="article-comments__heading">{{ 'blog.comment_form_title' | t }}</h2>

        {% if form.posted_successfully? %}
          <div class="article-comments__success" role="status">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {{ 'blog.comment_submitted' | t }}
          </div>
        {% endif %}

        {{ form.errors | default_errors }}

        <div class="article-comments__fields">
          <div class="article-comments__field">
            <label for="CommentAuthor">{{ 'blog.comment_form_name' | t }}</label>
            <input type="text" name="comment[author]" id="CommentAuthor" value="{{ form.author }}" autocomplete="name" required>
          </div>

          <div class="article-comments__field">
            <label for="CommentEmail">{{ 'blog.comment_form_email' | t }}</label>
            <input type="email" name="comment[email]" id="CommentEmail" value="{{ form.email }}" autocomplete="email" required>
          </div>

          <div class="article-comments__field article-comments__field--full">
            <label for="CommentBody">{{ 'blog.comment_form_body' | t }}</label>
            <textarea name="comment[body]" id="CommentBody" rows="5" required>{{ form.body }}</textarea>
          </div>

          <div class="article-comments__field article-comments__field--full">
            <button type="submit" class="button button--primary">{{ 'blog.comment_form_submit' | t }}</button>
          </div>
        </div>
      {% endform %}

    </div>
  </section>
{% endif %}

{% stylesheet %}
  .article-page {
    padding-block: 48px 72px;
  }

  .article-page__inner {
    width: min(100% - 32px, 760px);
    margin-inline: auto;
    display: grid;
    gap: 32px;
  }

  .article-page__breadcrumb {
    font-size: calc(0.8rem * var(--body-scale, 1));
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-foreground) 55%, transparent);
  }

  .article-page__breadcrumb a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-page__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 12px;
  }

  .article-page__tag {
    display: inline-block;
    padding: 3px 10px;
    font-size: calc(0.72rem * var(--body-scale, 1));
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid currentColor;
    border-radius: 999px;
    color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
    text-decoration: none;
  }

  .article-page__tag:hover {
    color: var(--color-foreground);
  }

  .article-page__title {
    margin: 0 0 12px;
    font-size: calc(clamp(1.8rem, 4vw, 2.8rem) * var(--heading-scale, 1));
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .article-page__meta {
    margin: 0;
    font-size: calc(0.85rem * var(--body-scale, 1));
    color: color-mix(in srgb, var(--color-foreground) 55%, transparent);
  }

  .article-page__hero {
    border-radius: var(--style-border-radius-theme);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .article-page__hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-page__body {
    font-size: calc(1.05rem * var(--body-scale, 1));
    line-height: 1.75;
  }

  .article-page__footer {
    padding-top: 16px;
    border-top: 1px solid color-mix(in srgb, var(--color-foreground) 8%, transparent);
  }

  .article-page__back-link {
    font-size: calc(0.9rem * var(--body-scale, 1));
    color: color-mix(in srgb, var(--color-foreground) 65%, transparent);
    text-decoration: none;
  }

  .article-page__back-link:hover {
    color: var(--color-foreground);
  }

  /* Comments */
  .article-comments {
    padding-block: 48px;
    border-top: 1px solid color-mix(in srgb, var(--color-foreground) 8%, transparent);
  }

  .article-comments__inner {
    width: min(100% - 32px, 760px);
    margin-inline: auto;
    display: grid;
    gap: 32px;
  }

  .article-comments__heading {
    margin: 0;
    font-size: calc(1.4rem * var(--heading-scale, 1));
  }

  .article-comments__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 24px;
  }

  .article-comments__item {
    padding: 20px;
    border: 1px solid color-mix(in srgb, var(--color-foreground) 8%, transparent);
    border-radius: var(--style-border-radius-theme);
    display: grid;
    gap: 8px;
  }

  .article-comments__author {
    margin: 0;
    font-weight: 600;
  }

  .article-comments__date {
    margin: 0;
    font-size: calc(0.8rem * var(--body-scale, 1));
    color: color-mix(in srgb, var(--color-foreground) 50%, transparent);
  }

  .article-comments__body {
    line-height: 1.6;
  }

  .article-comments__success {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 18px;
    background: color-mix(in srgb, #2ecc71 10%, transparent);
    border: 1px solid color-mix(in srgb, #2ecc71 40%, transparent);
    border-radius: var(--style-border-radius-theme);
    color: #1a7a42;
    font-size: calc(0.95rem * var(--body-scale, 1));
  }

  .article-comments__fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .article-comments__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .article-comments__field--full {
    grid-column: 1 / -1;
  }

  .article-comments__field label {
    font-size: calc(0.85rem * var(--body-scale, 1));
    font-weight: 500;
  }

  .article-comments__field input,
  .article-comments__field textarea {
    padding: 10px 14px;
    font: inherit;
    font-size: calc(var(--type-body-size) * var(--body-scale, 1));
    border: 1px solid var(--colorBorder);
    border-radius: var(--style-border-radius-inputs);
    background: var(--color-background);
    color: var(--color-foreground);
  }

  .article-comments__field input:focus,
  .article-comments__field textarea:focus {
    outline: none;
    border-color: var(--color-foreground);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-foreground) 10%, transparent);
  }

  .article-comments__field textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.6;
  }

  @media (max-width: 749px) {
    .article-comments__fields {
      grid-template-columns: 1fr;
    }

    .article-comments__field--full {
      grid-column: 1;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.article",
  "settings": [
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_scale",
      "label": "Heading font size",
      "min": 60,
      "max": 160,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "body_font_scale",
      "label": "Body font size",
      "min": 60,
      "max": 160,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ]
}
{% endschema %}

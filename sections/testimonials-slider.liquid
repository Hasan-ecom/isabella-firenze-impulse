{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign padding_top = 36
  assign padding_bottom = 36
  assign background_color = section.settings.color_scheme.settings.background
  assign full_width = section.settings.full_width

  assign heading = section.settings.heading
  assign heading_size = section.settings.heading_size
  assign scheme_text = section.settings.color_scheme.settings.text
  assign heading_color = scheme_text

  assign sub_heading = section.settings.sub_heading

  assign slider_view = section.settings.slider_view
  assign slider_view_mobile = section.settings.slider_view_mobile
  assign slider_gap = section.settings.slider_gap
  assign slider_gap_mobile = section.settings.slider_gap_mobile
  assign slider_view_tablet = slider_view | times: 0.5 | at_least: 1.0

  assign autoplay = section.settings.autoplay

  assign card_radius = section.settings.card_radius
  assign card_border_color = section.settings.card_border_color
  assign card_bg_color = section.settings.card_bg_color
  assign card_shadow = section.settings.card_shadow

  assign media_ratio = section.settings.media_ratio
  case media_ratio
    when 'portrait'
      assign media_aspect = '9.6 / 12'
    when 'big_portrait'
      assign media_aspect = '9.6 / 16'
    when 'landscape'
      assign media_aspect = '12 / 9'
    when 'square'
      assign media_aspect = '1 / 1'
    else
      assign media_aspect = 'auto'
  endcase

  assign stars_icon = section.settings.stars_icon
  assign stars_color = section.settings.stars_color

  assign text_size = section.settings.text_size
  assign text_color = section.settings.text_color

  assign author_color = section.settings.author_color

  assign arrow_show_desktop = section.settings.arrow_show_desktop
  assign arrow_show_mobile = section.settings.arrow_show_mobile

  assign dots_show_desktop = section.settings.dots_show_desktop
  assign dots_show_mobile = section.settings.dots_show_mobile
-%}

{%- style -%}
  .section-{{ section.id }}-settings {
    margin: 0 auto;
    padding-top: {{ padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    {% unless full_width %}max-width: 120rem;{% endunless %}
  }

  .testimonials-heading-{{ section.id }} {
    text-align: center;
  }

  .testimonials-heading-{{ section.id }} * {
    margin: 0;
    font-size: {{ heading_size }}px;
    color: {{ heading_color }};
    line-height: 130%;
  }

  .testimonials-subheading-{{ section.id }} {
    margin-top: 9px;
    text-align: center;
  }

  .testimonials-subheading-{{ section.id }} * {
    margin: 0;
    font-size: 16px;
    color: {{ heading_color }};
    line-height: 130%;
  }

  .testimonials-slider-{{ section.id }} {
    margin-top: 15px;
    margin-left: -1.5rem;
    margin-right: -1.5rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .testimonials-slider-{{ section.id }} .swiper-wrapper {
    align-items: stretch;
  }

  /* Pre-init layout: approximates the slider so nothing jumps when Swiper mounts */
  .testimonials-slider-{{ section.id }}:not(.swiper-initialized) {
    overflow: hidden;
  }

  .testimonials-slider-{{ section.id }}:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
  }

  .testimonials-slider-{{ section.id }}:not(.swiper-initialized) .testimonials-slide-{{ section.id }} {
    flex-shrink: 0;
    width: calc(100% / {{ slider_view_mobile }} - {{ slider_gap_mobile }}px);
    margin-right: {{ slider_gap_mobile }}px;
  }

  .testimonials-slide-{{ section.id }} {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 16px;
    border-radius: {{ card_radius }}px;
    border: 1px solid {{ card_border_color }};
    background-color: {{ card_bg_color }};
    {% if card_shadow %}box-shadow: rgba(0, 0, 0, 0.08) 0px 4px 12px;{% endif %}
    box-sizing: border-box;
    height: auto;
    overflow: hidden;
  }

  .testimonials-content-{{ section.id }} {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .testimonials-stars-{{ section.id }} {
    margin-top: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1px;
  }

  .testimonials-stars-{{ section.id }} svg,
  .testimonials-stars-{{ section.id }} img {
    display: block;
    width: 16px;
    height: 16px;
    object-fit: cover;
  }

  .testimonials-text-{{ section.id }} {
    margin-top: 9px;
    text-align: center;
  }

  .testimonials-text-{{ section.id }} * {
    margin: 0;
    font-size: {{ text_size }}px;
    color: {{ text_color }};
    line-height: 130%;
  }

  .testimonials-author-{{ section.id }} {
    margin-top: 9px;
    text-align: center;
  }

  .testimonials-author-{{ section.id }} * {
    margin: 0;
    font-size: 14px;
    color: {{ author_color }};
    line-height: 130%;
  }

  .testimonials-media-{{ section.id }} {
    border-radius: {{ card_radius }}px;
    overflow: hidden;
    position: relative;
    aspect-ratio: {{ media_aspect }};
  }

  .testimonials-media-{{ section.id }} img,
  .testimonials-media-{{ section.id }} svg,
  .testimonials-media-{{ section.id }} video,
  .testimonials-media-{{ section.id }} iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    box-shadow: none;
    object-fit: cover;
  }

  .testimonials-media-{{ section.id }} > svg {
    background-color: #DADADA;
  }

  .testimonials-video-btn-wrapper-{{ section.id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    transition: opacity 0.25s ease;
  }

  .testimonials-video-btn-wrapper-{{ section.id }}.active {
    opacity: 0;
    pointer-events: none;
  }

  .testimonials-video-btn-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    background-color: #FFFFFF;
    overflow: hidden;
  }

  .testimonials-video-btn-{{ section.id }} img,
  .testimonials-video-btn-{{ section.id }} svg {
    display: block;
    width: 20px;
    height: 20px;
    object-fit: cover;
  }

  .testimonials-video-btn-{{ section.id }} svg {
    margin-left: 2px;
  }

  .testimonials-navigation-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    margin-top: 30px;
  }

  .testimonials-btn-prev-{{ section.id }},
  .testimonials-btn-next-{{ section.id }} {
    position: static;
    display: {% if arrow_show_mobile %}flex{% else %}none{% endif %};
    align-items: center;
    justify-content: center;
    flex: 0 0 44px;
    width: 44px;
    height: 44px;
    background: transparent;
    transition: opacity 0.25s ease, transform 0.25s ease;
    cursor: pointer;
    -webkit-appearance: none;
    border: 0;
    box-shadow: none;
    padding: 0;
  }

  .testimonials-btn-prev-{{ section.id }} svg,
  .testimonials-btn-next-{{ section.id }} svg {
    width: 36px;
    height: auto;
    display: block;
  }

  .testimonials-btn-prev-{{ section.id }} svg path,
  .testimonials-btn-next-{{ section.id }} svg path {
    fill: {{ scheme_text }};
  }

  .testimonials-btn-prev-{{ section.id }}:hover {
    transform: translateX(-3px);
  }

  .testimonials-btn-next-{{ section.id }}:hover {
    transform: translateX(3px);
  }

  .testimonials-btn-prev-{{ section.id }}.swiper-button-disabled,
  .testimonials-btn-next-{{ section.id }}.swiper-button-disabled {
    opacity: 0.25;
    pointer-events: none;
  }

  .testimonials-pagination-{{ section.id }} {
    position: static;
    width: auto;
    display: {% if dots_show_mobile %}flex{% else %}none{% endif %};
    gap: 6px;
    justify-content: center;
    align-items: center;
  }

  .testimonials-pagination-{{ section.id }} .swiper-pagination-bullet {
    flex: 0 0 auto;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background-color: color-mix(in srgb, {{ scheme_text }} 28%, transparent);
    border: 0;
    opacity: 1;
    transition: width 0.3s ease, background-color 0.3s ease;
  }

  .testimonials-pagination-{{ section.id }} .swiper-pagination-bullet:hover {
    background-color: color-mix(in srgb, {{ scheme_text }} 55%, transparent);
  }

  .testimonials-pagination-{{ section.id }} .swiper-pagination-bullet.swiper-pagination-bullet-active {
    width: 22px;
    background-color: {{ scheme_text }};
  }

  .testimonials-video-{{ section.id }} {
    position: relative;
    z-index: 1;
    height: 100%;
    width: 100%;
    cursor: pointer;
  }

  .testimonials-video-poster-{{ section.id }} {
    position: absolute;
    z-index: 1;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .testimonials-video-poster-{{ section.id }}.active img {
    display: none;
  }

  @media (min-width: 1024px) {
    .section-{{ section.id }}-settings {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      padding-left: 5rem;
      padding-right: 5rem;
    }

    .testimonials-subheading-{{ section.id }} {
      margin-top: 12px;
    }

    .testimonials-subheading-{{ section.id }} * {
      font-size: 18px;
    }

    .testimonials-slider-{{ section.id }} {
      margin-top: 20px;
      margin-left: -5rem;
      margin-right: -5rem;
      padding-left: 5rem;
      padding-right: 5rem;
    }

    .testimonials-slider-{{ section.id }}:not(.swiper-initialized) .testimonials-slide-{{ section.id }} {
      width: calc(100% / {{ slider_view }} - {{ slider_gap }}px);
      margin-right: {{ slider_gap }}px;
    }

    .testimonials-slide-{{ section.id }} {
      padding: 20px;
    }

    .testimonials-video-btn-{{ section.id }} {
      width: 50px;
      height: 50px;
    }

    .testimonials-video-btn-{{ section.id }} img,
    .testimonials-video-btn-{{ section.id }} svg {
      width: 25px;
      height: 25px;
    }

    .testimonials-stars-{{ section.id }},
    .testimonials-text-{{ section.id }},
    .testimonials-author-{{ section.id }},
    .testimonials-subheading-{{ section.id }} {
      margin-top: 12px;
    }

    .testimonials-navigation-{{ section.id }} {
      margin-top: 40px;
      gap: 20px;
    }

    .testimonials-btn-prev-{{ section.id }},
    .testimonials-btn-next-{{ section.id }} {
      display: {% if arrow_show_desktop %}flex{% else %}none{% endif %};
    }

    .testimonials-pagination-{{ section.id }} {
      display: {% if dots_show_desktop %}flex{% else %}none{% endif %};
      gap: 10px;
    }
  }
{%- endstyle -%}

<div id="review" class="section-{{ section.id }} testimonials-{{ section.id }}" style="background-color: {{ background_color }};">
  <div class="section-{{ section.id }}-settings">
    {% if heading != blank %}
      <div class="testimonials-heading-{{ section.id }}">
        {{ heading }}
      </div>
    {% endif %}

    {% if sub_heading != blank %}
      <div class="testimonials-subheading-{{ section.id }}">
        {{ sub_heading }}
      </div>
    {% endif %}

    <div class="testimonials-slider-{{ section.id }} swiper">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="testimonials-slide-{{ section.id }} swiper-slide" {{ block.shopify_attributes }}>
            {% unless block.settings.media_style == 'none' %}
              <div class="testimonials-media-{{ section.id }}">
                {% if block.settings.media_style == 'image' %}
                  {% if block.settings.image != blank %}
                    <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.image.alt }}" loading="lazy">
                  {% else %}
                    {{ 'image' | placeholder_svg_tag }}
                  {% endif %}
                {% elsif block.settings.media_style == 'video' %}
                  <div class="testimonials-video-btn-element testimonials-video-btn-wrapper-{{ section.id }}">
                    <div class="testimonials-video-btn-{{ section.id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 520 520">
                        <path d="M222.842,58.6c17.279-27.248,57.037-27.248,74.317,0l180,283.84C495.732,371.731,474.685,410,440,410H80c-34.689,0-55.736-38.269-37.158-67.564Z" transform="translate(497 0) rotate(90)" fill="#000000"></path>
                      </svg>
                    </div>
                  </div>

                  <div class="testimonials-video-{{ section.id }}">
                    {% if block.settings.poster != blank %}
                      <div class="testimonials-video-poster-{{ section.id }}">
                        <img src="{{ block.settings.poster | image_url: width: 800 }}" alt="{{ block.settings.poster.alt }}" loading="lazy">
                      </div>
                    {% endif %}
                    {%- if block.settings.video == null and block.settings.video_url != null -%}
                      {% assign video_id = block.settings.video_url.id %}
                      {% assign loop_param = '&loop=1&playlist=' | append: video_id %}
                      {%- if block.settings.video_url.type == 'youtube' -%}
                        <iframe
                          data-src="https://www.youtube.com/embed/{{ video_id }}?enablejsapi=1{{ loop_param }}"
                          class="lazy"
                          allow="autoplay; encrypted-media"
                          allowfullscreen
                          loading="lazy"
                          title="Testimonial video"
                        ></iframe>
                      {%- else -%}
                        <iframe
                          data-src="https://player.vimeo.com/video/{{ video_id }}{{ loop_param }}"
                          class="lazy"
                          allow="autoplay; encrypted-media"
                          allowfullscreen
                          loading="lazy"
                          title="Testimonial video"
                        ></iframe>
                      {% endif %}
                    {% else %}
                      <video data-src="{{ block.settings.video.sources[1].url }}" {% if block.settings.controls %}controls{% endif %} playsinline preload="none" loop class="lazy"></video>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            {% endunless %}

            <div class="testimonials-content-{{ section.id }}">
              {% if block.settings.stars_count != 0 %}
                <div class="testimonials-stars-{{ section.id }}">
                  {% if stars_icon != blank %}
                    {% for item in (1..block.settings.stars_count) %}
                      <img src="{{ stars_icon | image_url: width: 100 }}" alt="{{ stars_icon.alt }}" loading="lazy">
                    {% endfor %}
                  {% else %}
                    {% liquid
                      assign stars_count = block.settings.stars_count
                    %}
                    {% for i in (1..5) %}
                      {% liquid
                        assign star_prev = i | minus: 1
                        assign star_half = false
                        if stars_count > star_prev and stars_count < i
                          assign star_half = true
                        endif
                      %}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="19" viewBox="0 0 20 19" fill="none">
                        {% if star_half %}
                          <defs>
                            <linearGradient id="star-grad-{{ block.id }}-{{ i }}">
                              <stop offset="50%" stop-color="{{ stars_color }}" />
                              <stop offset="50%" stop-color="{{ stars_color }}" stop-opacity="0" />
                            </linearGradient>
                          </defs>
                        {% endif %}
                        <path
                          stroke="{{ stars_color }}"
                          d="M10 0L12.9389 5.95492L19.5106 6.90983L14.7553 11.5451L15.8779 18.0902L10 15L4.12215 18.0902L5.24472 11.5451L0.489435 6.90983L7.06107 5.95492L10 0Z"
                          fill="{% if star_half %}url(#star-grad-{{ block.id }}-{{ i }}){% elsif stars_count >= i %}{{ stars_color }}{% else %}none{% endif %}"
                        ></path>
                      </svg>
                    {% endfor %}
                  {% endif %}
                </div>
              {% endif %}
              {% if block.settings.text != blank %}
                <div class="testimonials-text-{{ section.id }}">
                  {{ block.settings.text }}
                </div>
              {% endif %}
              {% if block.settings.author != blank %}
                <div class="testimonials-author-{{ section.id }}">{{ block.settings.author }}</div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
      <div class="testimonials-navigation-{{ section.id }}">
        <button class="testimonials-btn-prev-{{ section.id }}" type="button" aria-label="{{ 'sections.hero.previous_slide' | t }}">
          <svg width="92" height="38" viewBox="0 0 92 38" fill="none" xmlns="http://www.w3.org/2000/svg" style="transform: rotate(-180deg);">
            <path d="M72.472 0L71.063 1.409L87.303 17.649H0V19.643H87.3L71.06 35.883L72.469 37.293L91.115 18.646L72.472 0Z" fill="black"/>
          </svg>
        </button>
        <div class="testimonials-pagination-{{ section.id }} swiper-pagination"></div>
        <button class="testimonials-btn-next-{{ section.id }}" type="button" aria-label="{{ 'sections.hero.next_slide' | t }}">
          <svg width="92" height="38" viewBox="0 0 92 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M72.472 0L71.063 1.409L87.303 17.649H0V19.643H87.3L71.06 35.883L72.469 37.293L91.115 18.646L72.472 0Z" fill="black"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>

<script>
  (function () {
    var sectionId = '{{ section.id }}';
    var initAttempts = 0;
    var currentSlider = null;
    var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function pauseVideo(slide) {
      var video = slide.querySelector('video');
      var frame = slide.querySelector('iframe');
      var btn = slide.querySelector('.testimonials-video-btn-wrapper-' + sectionId);
      var poster = slide.querySelector('.testimonials-video-poster-' + sectionId);
      if (video) video.pause();
      if (frame && frame.src) frame.src = frame.src.replace('&autoplay=1', '');
      if (btn) btn.classList.remove('active');
      if (poster) poster.classList.remove('active');
    }

    function bindVideoControls(container) {
      container.querySelectorAll('.testimonials-slide-' + sectionId).forEach(function (slide) {
        if (slide.dataset.videoBound) return;
        slide.dataset.videoBound = 'true';

        var btn = slide.querySelector('.testimonials-video-btn-wrapper-' + sectionId);
        var poster = slide.querySelector('.testimonials-video-poster-' + sectionId);
        var video = slide.querySelector('video');
        var frame = slide.querySelector('iframe');

        if (btn) {
          btn.addEventListener('click', function () {
            btn.classList.add('active');
            if (poster) poster.classList.add('active');
            if (video) video.play();
            if (frame && frame.src && frame.src.indexOf('&autoplay=1') === -1) {
              frame.src += '&autoplay=1';
            }
          });
        }

        if (poster) {
          poster.addEventListener('click', function () {
            pauseVideo(slide);
          });
        }
      });
    }

    function lazyLoadMedia(container) {
      var lazyEls = container.querySelectorAll('.lazy');
      if ('IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function (entries, obs) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            var el = entry.target;
            if (el.dataset.src) el.src = el.dataset.src;
            el.classList.remove('lazy');
            obs.unobserve(el);
          });
        }, { rootMargin: '200px' });
        lazyEls.forEach(function (el) { observer.observe(el); });
      } else {
        lazyEls.forEach(function (el) { if (el.dataset.src) el.src = el.dataset.src; });
      }
    }

    function initSlider() {
      var container = document.querySelector('.testimonials-slider-' + sectionId);
      if (!container) return;

      if (typeof Swiper === 'undefined') {
        if (initAttempts++ < 50) setTimeout(initSlider, 100);
        return;
      }

      if (container.swiper) container.swiper.destroy(true, true);

      var slider = new Swiper(container, {
        speed: 400,
        rewind: true,
        watchOverflow: true,
        {% if autoplay %}
        autoplay: prefersReducedMotion ? false : {
          delay: 5000,
          disableOnInteraction: false,
          pauseOnMouseEnter: true
        },
        {% endif %}
        navigation: {
          nextEl: '.testimonials-btn-next-' + sectionId,
          prevEl: '.testimonials-btn-prev-' + sectionId
        },
        pagination: {
          el: '.testimonials-pagination-' + sectionId,
          type: 'bullets',
          clickable: true
        },
        breakpoints: {
          0: {
            spaceBetween: {{ slider_gap_mobile }},
            slidesPerView: {{ slider_view_mobile }}
          },
          768: {
            spaceBetween: {{ slider_gap_mobile }},
            slidesPerView: {{ slider_view_tablet }}
          },
          1024: {
            spaceBetween: {{ slider_gap }},
            slidesPerView: {{ slider_view }}
          }
        }
      });

      currentSlider = slider;

      slider.on('slideChange', function () {
        slider.slides.forEach(function (slide) {
          if (!slide.classList.contains('swiper-slide-active')) pauseVideo(slide);
        });
      });

      bindVideoControls(container);
      lazyLoadMedia(container);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSlider);
    } else {
      initSlider();
    }

    document.addEventListener('shopify:section:load', function (event) {
      if (event.detail && event.detail.sectionId === sectionId) initSlider();
    });

    {% if autoplay %}
    if (!prefersReducedMotion) {
      document.addEventListener('visibilitychange', function () {
        if (currentSlider && currentSlider.autoplay) {
          if (document.hidden) {
            currentSlider.autoplay.stop();
          } else {
            currentSlider.autoplay.start();
          }
        }
      });
    }
    {% endif %}
  })();
</script>

{% schema %}
{
  "name": "Testimonials Custom",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<h2>Loved by everyone, everywhere. Don't miss out.</h2>"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 12,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 30
    },
    {
      "type": "richtext",
      "id": "sub_heading",
      "label": "Sub-heading"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "range",
      "id": "slider_view",
      "min": 2,
      "max": 6,
      "step": 0.1,
      "label": "Slides per view",
      "default": 5
    },
    {
      "type": "range",
      "id": "slider_view_mobile",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Slides per view - Mobile",
      "default": 1.3
    },
    {
      "type": "range",
      "id": "slider_gap",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Gap between slides",
      "default": 28
    },

{% comment %}
  This section is used in the password template to render the landing page shown
  when password protection is applied to a store.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/password
{% endcomment %}

{%- liquid
  assign logo = section.settings.logo
  assign logo_width = section.settings.logo_width
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign bg_image = section.settings.background_image
  assign overlay = section.settings.overlay_opacity | divided_by: 100.0
-%}

{%- style -%}
  .password-{{ section.id }} {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 24px;
    text-align: center;
    background-color: var(--color-background);
    color: var(--color-foreground);
    font-family: var(--font-primary--family);
  }

  {% if bg_image != blank %}
    .password-{{ section.id }} {
      color: #ffffff;
    }

    .password-{{ section.id }}__bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .password-{{ section.id }}__bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .password-{{ section.id }}__bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background-color: rgba(0, 0, 0, {{ overlay }});
    }
  {% endif %}

  .password-{{ section.id }}__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 460px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .password-{{ section.id }}__logo img {
    display: block;
    width: {{ logo_width }}px;
    height: auto;
    margin: 0 auto;
  }

  .password-{{ section.id }}__logo-text {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 28px;
    letter-spacing: 0.02em;
  }

  .password-{{ section.id }}__heading {
    margin: 0;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-style: var(--font-heading--style);
    font-size: clamp(28px, 5vw, 44px);
    line-height: 1.1;
  }

  .password-{{ section.id }}__subheading {
    margin: 0;
    font-size: 16px;
    line-height: 1.5;
    opacity: 0.85;
  }

  .password-{{ section.id }}__subheading p {
    margin: 0;
  }

  .password-{{ section.id }}__message {
    font-size: 15px;
    line-height: 1.5;
    opacity: 0.85;
  }

  .password-{{ section.id }}__form {
    width: 100%;
    margin-top: 4px;
  }

  .password-{{ section.id }}__field {
    display: flex;
    gap: 10px;
    width: 100%;
  }

  .password-{{ section.id }}__input {
    flex: 1 1 auto;
    width: 100%;
    height: 52px;
    padding: 0 16px;
    font-size: 15px;
    font-family: inherit;
    color: var(--color-foreground);
    background-color: var(--color-background);
    border: 1px solid var(--colorBorder);
    border-radius: var(--style-border-radius-inputs);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .password-{{ section.id }}__input:focus {
    border-color: var(--color-foreground);
  }

  .password-{{ section.id }}__button {
    flex: 0 0 auto;
    height: 52px;
    padding: 0 28px;
    font-size: 15px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
    color: var(--button-primary-text);
    background-color: var(--button-primary-background);
    border: 1px solid var(--button-primary-border);
    border-radius: var(--style-border-radius-buttons);
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .password-{{ section.id }}__button:hover {
    color: var(--button-primary-text-hover);
    background-color: var(--button-primary-background-hover);
    border-color: var(--button-primary-border-hover);
  }

  .password-{{ section.id }}__errors {
    margin: 0 0 4px;
    color: #d02b2b;
    font-size: 14px;
  }

  .password-{{ section.id }}__footer {
    margin-top: 8px;
    font-size: 13px;
    opacity: 0.7;
  }

  .password-{{ section.id }}__footer a {
    color: inherit;
  }

  .password-{{ section.id }}__label {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 540px) {
    .password-{{ section.id }}__field {
      flex-direction: column;
    }

    .password-{{ section.id }}__button {
      width: 100%;
    }
  }
{%- endstyle -%}

<div class="password-{{ section.id }}">
  {% if bg_image != blank %}
    <div class="password-{{ section.id }}__bg">
      <img
        src="{{ bg_image | image_url: width: 2400 }}"
        alt=""
        loading="eager"
        width="{{ bg_image.width }}"
        height="{{ bg_image.height }}"
      >
    </div>
  {% endif %}

  <div class="password-{{ section.id }}__inner">
    <div class="password-{{ section.id }}__logo">
      {% if logo != blank %}
        <img
          src="{{ logo | image_url: width: 600 }}"
          alt="{{ shop.name | escape }}"
          loading="eager"
          width="{{ logo_width }}"
        >
      {% else %}
        <span class="password-{{ section.id }}__logo-text">{{ shop.name }}</span>
      {% endif %}
    </div>

    {% if heading != blank %}
      <h1 class="password-{{ section.id }}__heading">{{ heading }}</h1>
    {% endif %}

    {% if subheading != blank %}
      <div class="password-{{ section.id }}__subheading">{{ subheading }}</div>
    {% endif %}

    {% if shop.password_message != blank %}
      <div class="password-{{ section.id }}__message">{{ shop.password_message }}</div>
    {% endif %}

    {% form 'storefront_password' %}
      {% if form.errors %}
        <div class="password-{{ section.id }}__errors" id="password-errors">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <div class="password-{{ section.id }}__form">
        <div class="password-{{ section.id }}__field">
          <label class="password-{{ section.id }}__label" for="password-input">
            {{ 'password.password' | t }}
          </label>
          <input
            class="password-{{ section.id }}__input"
            type="password"
            name="password"
            id="password-input"
            placeholder="{{ 'password.password' | t }}"
            autocomplete="current-password"
            {% if form.errors %}aria-describedby="password-errors"{% endif %}
          >
          <button class="password-{{ section.id }}__button" type="submit">
            {{ 'password.enter' | t }}
          </button>
        </div>
      </div>
    {% endform %}

    {% if section.settings.show_powered_by %}
      <div class="password-{{ section.id }}__footer">
        {{ powered_by_link }}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "t:general.password",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Falls back to the store name when empty."
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 320,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 160
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Opening soon"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Enter the password to view the store.</p>"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Optional. Displayed full-screen behind the content."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Image overlay opacity",
      "default": 40
    },
    {
      "type": "header",
      "content": "Footer"
    },
    {
      "type": "checkbox",
      "id": "show_powered_by",
      "label": "Show \"Powered by Shopify\"",
      "default": true
    }
  ]
}
{% endschema %}

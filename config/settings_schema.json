[
  {
    "name": "theme_info",
    "theme_name": "Wealth Kings Custom Thema",
    "theme_version": "1.0.0",
    "theme_author": "YC Web Design",
    "theme_documentation_url": "https://ycwebdesign.com/theme-docs",
    "theme_support_url": "https://ycwebdesign.com/theme-support"
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "16 x 16px .png recommended"
      }
    ]
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "Body font"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "work_sans_n4",
        "label": "Heading font"
      },
      {
        "type": "header",
        "content": "Body text"
      },
      {
        "type": "range",
        "id": "type_body_size",
        "min": 14,
        "max": 22,
        "step": 1,
        "unit": "px",
        "label": "Base body size",
        "default": 16
      },
      {
        "type": "range",
        "id": "type_body_line_height",
        "min": 120,
        "max": 200,
        "step": 5,
        "unit": "%",
        "label": "Body line height",
        "default": 160
      },
      {
        "type": "range",
        "id": "type_body_letter_spacing",
        "min": -5,
        "max": 10,
        "step": 1,
        "unit": "%",
        "label": "Body letter spacing",
        "default": 0
      },
      {
        "type": "header",
        "content": "Headings"
      },
      {
        "type": "range",
        "id": "type_heading_line_height",
        "min": 90,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Heading line height",
        "default": 110
      },
      {
        "type": "range",
        "id": "type_heading_letter_spacing",
        "min": -10,
        "max": 20,
        "step": 1,
        "unit": "%",
        "label": "Heading letter spacing",
        "default": 0
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "range",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "min": 1200,
        "max": 1800,
        "step": 20,
        "unit": "px",
        "default": 1440
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      },
      {
        "type": "range",
        "id": "theme_corner_radius",
        "min": 0,
        "max": 32,
        "step": 1,
        "unit": "px",
        "label": "Theme corner radius",
        "default": 16
      },
      {
        "type": "range",
        "id": "product_tile_corner_radius",
        "min": 0,
        "max": 32,
        "step": 1,
        "unit": "px",
        "label": "Product tile corner radius",
        "default": 16
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Global defaults"
      },
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#000000",
        "label": "t:labels.foreground"
      },
      {
        "type": "color",
        "id": "sale_price_color",
        "default": "#000000",
        "label": "Sale price color"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      },
      {
        "type": "header",
        "content": "Color schemes"
      },
      {
        "type": "paragraph",
        "content": "Assign a scheme to each section via its settings. Four schemes are pre-loaded: Light, Dark, Warm, and Blush."
      },
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "label": "Background",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "text",
            "label": "Text",
            "default": "#000000"
          }
        ],
        "role": {
          "background": "background",
          "text": "text",
          "links": "text",
          "icons": "text",
          "primary_button": "text",
          "on_primary_button": "background",
          "primary_button_border": "text",
          "secondary_button": "background",
          "on_secondary_button": "text",
          "secondary_button_border": "text"
        }
      }
    ]
  },

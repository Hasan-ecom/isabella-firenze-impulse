    {
      "name": "Product tiles",
      "settings": [
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "checkbox",
          "id": "product_tile_show_title",
          "label": "Show product title",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "product_tile_show_price",
          "label": "Show product price",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "product_tile_show_compare_at_price",
          "label": "Show old price",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "product_tile_show_vendor",
          "label": "Show vendor",
          "default": false
        },
        {
          "type": "color",
          "id": "product_tile_price_color",
          "label": "New price color",
          "default": "#4A4A4A"
        },
        {
          "type": "color",
          "id": "product_tile_compare_price_color",
          "label": "Old price color",
          "default": "#7A7A7A"
        },
        {
          "type": "header",
          "content": "Sale badge"
        },
        {
          "type": "checkbox",
          "id": "product_tile_show_sale_badge",
          "label": "Show discount badge",
          "default": true
        },
        {
          "type": "select",
          "id": "product_tile_sale_badge_position",
          "label": "Badge position",
          "options": [
            {
              "value": "top-left",
              "label": "Top left"
            },
            {
              "value": "top-right",
              "label": "Top right"
            },
            {
              "value": "bottom-left",
              "label": "Bottom left"
            },
            {
              "value": "bottom-right",
              "label": "Bottom right"
            }
          ],
          "default": "top-left"
        },
        {
          "type": "color",
          "id": "product_tile_sale_badge_background",
          "label": "Badge background",
          "default": "#111111"
        },
        {
          "type": "color",
          "id": "product_tile_sale_badge_text_color",
          "label": "Badge text color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "product_tile_sale_badge_font_size",
          "min": 10,
          "max": 24,
          "step": 1,
          "unit": "px",
          "label": "Badge font size",
          "default": 13
        },
        {
          "type": "range",
          "id": "product_tile_sale_badge_corner_radius",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "px",
          "label": "Badge corner radius",
          "default": 0
        },
        {
          "type": "range",
          "id": "product_tile_sale_badge_offset_x",
          "min": 0,
          "max": 40,
          "step": 1,
          "unit": "px",
          "label": "Horizontal offset",
          "default": 12
        },
        {
          "type": "range",
          "id": "product_tile_sale_badge_offset_y",
          "min": 0,
          "max": 40,
          "step": 1,
          "unit": "px",
          "label": "Vertical offset",
          "default": 12
        },
        {
          "type": "range",
          "id": "product_tile_sale_badge_padding_x",
          "min": 6,
          "max": 24,
          "step": 1,
          "unit": "px",
          "label": "Horizontal padding",
          "default": 10
        },
        {
          "type": "range",
          "id": "product_tile_sale_badge_padding_y",
          "min": 4,
          "max": 18,
          "step": 1,
          "unit": "px",
          "label": "Vertical padding",
          "default": 6
        },
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "checkbox",
          "id": "enable_quick_shop",
          "label": "Enable quick shop feature",
          "default": false
      },
      {
        "type": "text",
        "id": "quick_shop_button_text",
        "label": "Quick shop button text",
        "default": "Quick view"
      },
      {
        "type": "select",
        "id": "product_tile_image_size",
        "label": "Force image size",
        "options": [
          {
            "value": "natural",
            "label": "Natural"
          },
          {
            "value": "square",
            "label": "Square (1:1)"
          },
          {
            "value": "portrait",
            "label": "Portrait (4:5)"
          },
          {
            "value": "landscape",
            "label": "Landscape (4:3)"
          }
        ],
        "default": "square"
      },
      {
        "type": "checkbox",
        "id": "product_tile_zoom_image",
        "label": "Zoom image to fill space",
        "default": false
      },
      {
        "type": "paragraph",
        "content": "No effect when grid image size set to 'Natural'."
      },
        {
          "type": "checkbox",
          "id": "product_tile_show_second_image",
          "label": "Hover to reveal second image",
          "default": true
        },
        {
          "type": "header",
          "content": "Color swatches"
        },
        {
          "type": "checkbox",
          "id": "enable_color_swatches",
        "label": "Enable color swatches",
        "default": false
      },
      {
        "type": "radio",
        "id": "product_tile_swatch_style",
        "label": "Swatch style",
        "options": [
          {
            "value": "round",
            "label": "Round"
          },
          {
            "value": "square",
            "label": "Square"
          }
        ],
        "default": "round"
      },
      {
        "type": "textarea",
        "id": "color_swatch_mappings",
        "label": "Color swatch mappings",
        "info": "One per line, for example: Black: #111111",
        "default": "Black: #111111\nWhite: #F5F5F5\nCream: #F3E7D3\nBeige: #D8C3A5\nNavy: #1F2A44"
      }
    ]
  },
  {
    "name": "Collection tiles",
    "settings": [
      {
        "type": "select",
        "id": "collection_tile_style",
        "label": "Style",
        "options": [
          {
            "value": "overlay",
            "label": "Text on image overlay"
          },
          {
            "value": "overlay_bg",
            "label": "Text on image with bg"
          },
          {
            "value": "below",
            "label": "Text below image"
          }
        ],
        "default": "below"
      },
      {
        "type": "paragraph",
        "content": "Text on image overlay uses a subtle bottom fade for contrast. Text on image with bg places the title inside a small background label over the image."
      },
      {
        "type": "select",
        "id": "collection_tile_shape",
        "label": "Shape",
        "options": [
          {
            "value": "square",
            "label": "Square"
          },
          {
            "value": "landscape",
            "label": "Landscape"
          },
          {
            "value": "portrait",
            "label": "Portrait"
          }
        ],
        "default": "square"
      },
      {
        "type": "select",
        "id": "collection_tile_image_source",
        "label": "Image",
        "options": [
          {
            "value": "first_product",
            "label": "First product"
          },
          {
            "value": "collection_image",
            "label": "Collection image"
          }
        ],
        "default": "collection_image"
      },
      {
        "type": "select",
        "id": "collection_tile_text_alignment",
        "label": "Text alignment",
        "options": [
          {
            "value": "left",
            "label": "Left"
          },
          {
            "value": "center",
            "label": "Center"
          },
          {
            "value": "right",
            "label": "Right"
          }
        ],
        "default": "left"
      },
      {
        "type": "paragraph",
        "content": "Text alignment applies to all collection tile styles. For text on image with bg, it also controls whether the label sits left, center, or right on the image."
      },
      {
        "type": "header",
        "content": "Text on image with bg only"
      },
      {
        "type": "paragraph",
        "content": "The settings below only apply when Style is set to Text on image with bg."
      },
      {
        "type": "color",
        "id": "collection_tile_text_color",
        "label": "Text color",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "collection_tile_text_background",
        "label": "Text BG",
        "default": "#111111"
      },
      {
        "type": "range",
        "id": "collection_tile_tint_opacity",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "%",
        "label": "Tint opacity",
        "default": 35
      },
      {
        "type": "color",
        "id": "collection_tile_tint_color",
        "label": "Tint color",
        "default": "#111111"
      }
    ]
  },
